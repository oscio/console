# Copy to .env (gitignored). Both apps/web and apps/api read from here via
# the shared dotenv loader in packages/auth.

# --- Postgres ---
# Matches docker-compose.yml. Override when pointing at the cluster's
# platform-infra Postgres.
DATABASE_URL=postgres://console:console@localhost:5433/console

# --- better-auth ---
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-32-bytes-base64
# Public origin of apps/web. Used to build OAuth redirect URIs.
BETTER_AUTH_URL=http://localhost:3000

# --- Keycloak (platform realm) ---
# Match infra/clusters/dev: auth.<domain>/realms/platform.
# docker-compose.yml overrides these to the in-memory mock OIDC provider.
KEYCLOAK_ISSUER_URL=https://auth.dev.openschema.io/realms/platform
KEYCLOAK_CLIENT_ID=console
KEYCLOAK_CLIENT_SECRET=replace-me-from-tfvars

# --- web → api ---
# Where apps/web fetches the accounts API. Server-side fetches use the
# in-cluster URL in prod; in dev both are localhost.
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- api ---
# CORS origin for the NestJS app.
WEB_URL=http://localhost:3000
PORT=3001
